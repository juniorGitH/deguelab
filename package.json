{
  "name": "degue-lab",
  "version": "1.0.0",
  "description": "Degue Lab - Boutique en ligne de Degue et Yaourt premium",
  "homepage": "https://deguelab.com",
  "scripts": {
    "start": "parcel src/index.html",
    "build": "parcel build src/index.html",
    "build-gh": "parcel build src/index.html --public-url \"/\" && powershell -Command \"Copy-Item -Path dist/index.html -Destination dist/404.html\" && powershell -Command \"Set-Content -Path dist/CNAME -Value 'e-a.codes'\"",
    "predeploy": "npm run build-gh",
    "deploy": "gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juniorGitH/Emmanuel_Amela.git"
  },
  "author": "Dreamer the Prince",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/juniorGitH/Emmanuel_Amela/issues"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.31.7",
    "gh-pages": "^4.0.0",
    "html-webpack-plugin": "^5.5.0",
    "parcel": "^2.7.0",
    "postcss": "^8.4.24",
    "prettier": "^2.7.1",
    "process": "^0.11.10",
    "serve": "^14.2.4",
    "tailwindcss": "^3.3.2"
  }
}